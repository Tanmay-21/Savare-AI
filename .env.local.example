# Supabase (browser-safe, used by the React frontend)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API base URL
# - Local dev: leave empty (Vite proxies /api/* to localhost:3001)
# - Production: set to your Railway deployment URL (no trailing slash)
VITE_API_BASE_URL=https://your-app.railway.app

# Server-side only (used by the Express API server, never sent to the browser)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CORS: allow your Vercel frontend to call the Railway API
FRONTEND_URL=https://your-app.vercel.app

# Optional: Gemini AI key
GEMINI_API_KEY=
